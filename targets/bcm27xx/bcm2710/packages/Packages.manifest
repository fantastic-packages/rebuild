Package: kmod-keys-encrypted
Version: 6.6.73-r1
Depends: kernel (=6.6.73~e7d7936686c419103beb03b86fa9c4d5-r1), kmod-crypto-cbc, kmod-crypto-hmac, kmod-crypto-rng, kmod-crypto-sha256, kmod-keys-trusted
Source: feeds/base/kernel/linux
SourceName: kernel
License: GPL-2.0-only
LicenseFiles: COPYING
Section: kernel
SourceDateEpoch: 1737582563
Architecture: aarch64_cortex-a53
Installed-Size: 40960
