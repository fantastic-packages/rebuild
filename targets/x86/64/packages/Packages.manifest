Package: kmod-keys-encrypted
Version: 6.6.141-r1
Depends: kernel (=6.6.141~97d496152a384382b014de7103201ba3-r1), kmod-crypto-cbc, kmod-crypto-hmac, kmod-crypto-rng, kmod-crypto-sha256, kmod-keys-trusted
